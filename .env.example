# Zendesk Help Center credentials
# (an admin or Help Center manager API token; instance subdomain only,
# without https:// or .zendesk.com)
ZENDESK_SUBDOMAIN=your-subdomain
ZENDESK_EMAIL=your-email@example.com
ZENDESK_API_TOKEN=your-api-token

# Locale for the Help Center translation API (article body lives on a translation).
ZENDESK_DEFAULT_LOCALE=en-us

# The articles surfaced in the SharePoint "Site Pages" library are configured
# in src/config/articles.js (ID + section name). Edit that file to add or
# remove articles \u2014 nothing else to change here.

PORT=3000
