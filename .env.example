# Zendesk Help Center credentials
# (an admin or Help Center manager API token; instance subdomain only,
# without https:// or .zendesk.com)
ZENDESK_SUBDOMAIN=your-subdomain
ZENDESK_EMAIL=your-email@example.com
ZENDESK_API_TOKEN=your-api-token

# The article that the mock SharePoint page edits.
# Find the ID at the end of the article URL:
#   https://<sub>.zendesk.com/hc/<locale>/articles/<ID>-<slug>
ZENDESK_DEFAULT_ARTICLE_ID=123456789
ZENDESK_DEFAULT_LOCALE=en-us

PORT=3000
